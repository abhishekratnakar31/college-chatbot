# ==========================================
# College Chatbot Environment Variables
# ==========================================

# ------------------------------------------
# Server Configuration
# ------------------------------------------
PORT=4000
ALLOWED_ORIGIN="*"

# ------------------------------------------
# Database Configuration
# ------------------------------------------
# PostgreSQL Connection String
DATABASE_URL="postgresql://username:password@localhost:5432/college_chatbot"

# Qdrant Vector Database
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY="" # Leave empty if running Qdrant locally without auth

# ------------------------------------------
# API Keys (External Services)
# ------------------------------------------
# OpenRouter API Key for LLM and Embeddings
OPENROUTER_API_KEY="sk-or-v1-your-api-key-here"

# Tavily API Key for Live Web Search
TAVILY_API_KEY="tvly-your-api-key-here"

# ------------------------------------------
# Frontend (Next.js) Configuration
# ------------------------------------------
# If placing this in the `web` folder, rename to `.env.local`
NEXT_PUBLIC_API_URL="http://127.0.0.1:4000"
